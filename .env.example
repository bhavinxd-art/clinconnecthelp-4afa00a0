# Easiest GitHub Pages option: Airtable public/shared CSV view.
# Use this if you want GitHub Pages with no exposed token.
VITE_AIRTABLE_CSV_URL=https://airtable.com/...

# Alternative Airtable API option (read-only, browser-visible).
# Create a Personal Access Token at https://airtable.com/create/tokens
# Scope: data.records:read   Access: only your Jobs base
VITE_AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
VITE_AIRTABLE_TABLE=Jobs
